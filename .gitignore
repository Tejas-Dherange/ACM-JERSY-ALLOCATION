dist/
*/dist/
.next/
*/.next/
out/
*/out/

# Prisma generated client
*/node_modules/.prisma/

# Docker
.docker/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# TypeScript
*.tsbuildinfo
