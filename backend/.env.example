# Backend Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/jerseydb?sslmode=require

# Redis (Docker service name in production, localhost in dev)
REDIS_URL=redis://redis:6379

# Neon Auth (Better Auth) – get from Neon Console → Auth → Configuration
# The base URL from your Neon Auth Configuration page
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
